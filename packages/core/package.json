{
  "name": "@slop-lab/dev-infra-manager-core",
  "version": "0.1.0",
  "description": "Provider-neutral runtime and workspace lifecycle APIs for DIM",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slop-lab/dev-infra-manager.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/slop-lab/dev-infra-manager#readme",
  "bugs": "https://github.com/slop-lab/dev-infra-manager/issues",
  "keywords": ["containers", "development", "isolation", "workspace"],
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-publish-package.mjs",
    "pack:dry-run": "pnpm run build && npm pack --dry-run ./dist",
    "publish:package": "pnpm run build && npm publish ./dist",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "22.15.34",
    "package.json-minifier": "0.0.6",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
