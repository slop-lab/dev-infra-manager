{
  "name": "@slop-lab/install-dim",
  "version": "0.1.0",
  "description": "Installer for optional DIM plugins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slop-lab/dev-infra-manager.git",
    "directory": "packages/install"
  },
  "homepage": "https://github.com/slop-lab/dev-infra-manager#readme",
  "bugs": "https://github.com/slop-lab/dev-infra-manager/issues",
  "keywords": ["cli", "installer", "plugins"],
  "private": true,
  "type": "module",
  "bin": {
    "install-dim": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-publish-package.mjs",
    "pack:dry-run": "pnpm run build && npm pack --dry-run ./dist",
    "publish:package": "pnpm run build && npm publish ./dist",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "22.15.34",
    "package.json-minifier": "0.0.6",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
